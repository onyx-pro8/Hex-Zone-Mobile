# API base URL (defaults to app.json extra.apiBaseUrl if unset)
EXPO_PUBLIC_API_BASE_URL=https://safe-zone-patrol-server.onrender.com

# Web app origin used to build deep links inside QR codes (member invites
# and guest access). Defaults to the API base URL when unset.
EXPO_PUBLIC_WEB_APP_BASE_URL=https://safe-zone-patrol-server.onrender.com
