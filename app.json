{
  "expo": {
    "name": "Safe Zone Patrol",
    "slug": "zone-weaver",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zoneweaver",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zoneweaver.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Safe Zone Patrol uses your camera to scan QR codes for zone access and member invites.",
        "NSLocationWhenInUseUsageDescription": "Safe Zone Patrol uses your location to anchor proximity-source zones to where you are right now.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.zoneweaver.mobile",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2F80ED",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Safe Zone Patrol to access your camera to scan QR codes."
        }
      ],
      "expo-secure-store",
      "expo-splash-screen",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Safe Zone Patrol uses your location to anchor proximity-source zones to where you are right now."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "apiBaseUrl": "https://zone-weaver-server-7ksef.ondigitalocean.app/",
      "webAppBaseUrl": "https://zone-weaver-server-7ksef.ondigitalocean.app/",
      "eas": {
        "projectId": "8e70e1cf-1392-465c-b756-75c31e97a836"
      }
    },
    "owner": "ihnatenkoandrii8s-organization"
  }
}
