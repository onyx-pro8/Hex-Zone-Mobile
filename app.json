{
  "expo": {
    "name": "Hex Zone",
    "slug": "zone-weaver",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hexzone",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hexzone.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Hex Zone uses your camera to scan QR codes for zone access and member invites.",
        "NSLocationWhenInUseUsageDescription": "Hex Zone uses your location to anchor proximity-source zones to where you are right now."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.hexzone.mobile",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF2DAA"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Hex Zone to access your camera to scan QR codes."
        }
      ],
      "expo-secure-store",
      "expo-splash-screen",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Hex Zone uses your location to anchor proximity-source zones to where you are right now."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "apiBaseUrl": "https://zone-weaver-wwws2.ondigitalocean.app",
      "eas": {
        "projectId": "f7e4abd1-8246-4b62-b78e-2f1c690d78ea"
      }
    },
    "owner": "ihnatenkoandrii"
  }
}
